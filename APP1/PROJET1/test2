
#include <stdio.h>
#include <ctype.h>
#include <stdbool.h>
#include <string.h>

// Fonction pour décaler un caractère
int decale(char l, int cle) {

    if (l >= 'A' && l <= 'Z') {
        return (char) (((l - 'A' + cle) % 26 + 26) % 26 + 'A');
    }
    
    else if (l >= 'a' && l <= 'z') {
        return (char) (((l - 'a' + cle) % 26 + 26) % 26 + 'a');
    }
    else {
        return l;
    }
}

int main() {

    char reponse[13];
    strncpy(reponse, "elio is here", sizeof(reponse) - 1);
    reponse[12] = '\0';  // Correct null termination

    // Appel de la fonction decale et affichage du résultat
    char resultat = decale('A', 3);
    printf("Résultat du décalage : %c\n", resultat);

    return 0;
}

